# --- REQUIRED -----------------------------------------------------------------

# Bearer token for HTTP auth. Generate with: openssl rand -hex 32
# The server REFUSES to start if this is empty. There is no default value.
MCP_BEARER_TOKEN=

# --- OPTIONAL -----------------------------------------------------------------

# Path to the hermes binary. Default: looked up on PATH.
# HERMES_BIN=/home/your-user/.local/bin/hermes

# Bind address. Default 127.0.0.1 — your tunnel (cloudflared/ngrok) reaches it.
# Do NOT bind to 0.0.0.0 unless you understand the implications.
# BIND_HOST=127.0.0.1

# Port. Default 8765.
# BIND_PORT=8765

# Max wall-clock seconds for a single hermes_ask call. Default 300.
# HERMES_TIMEOUT_SECONDS=300

# Optional comma-separated Hermes toolsets to restrict each call.
# Leave unset to use Hermes's default toolset.
# HERMES_TOOLSETS=web,filesystem

# Log level (DEBUG / INFO / WARNING / ERROR). Default INFO.
# DEBUG enables logging of full prompt bodies — leave at INFO unless debugging.
# LOG_LEVEL=INFO
